# Mainnet-only Rupi deployment configuration. Store real values in the host's
# secret manager; never commit a populated .env file.
NODE_ENV=production
RUPI_ENVIRONMENT=mainnet
ENABLE_PRODUCT_APP=true
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_GRIEVANCE_EMAIL=grievance@example.com

# PostgreSQL: SSL must be verified with the provider CA in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_CA_CERT=replace-with-provider-ca-pem
DATABASE_POOL_MAX=10

# Better Auth / passkeys / email OTP
BETTER_AUTH_SECRET=replace-with-32-or-more-random-characters
WEBAUTHN_RP_ID=app.example.com
RESEND_API_KEY=re_replace_with_resend_api_key
RESEND_FROM_EMAIL=Rupi <security@example.com>
WAITLIST_UNSUBSCRIBE_SECRET=replace-with-a-different-32-or-more-character-secret

# Durable public-endpoint throttling
UPSTASH_REDIS_REST_URL=https://replace-with-upstash-endpoint
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# Stellar Mainnet asset identity
STELLAR_NETWORK=mainnet
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_USDC_ISSUER=replace-with-verified-stellar-usdc-issuer-address

# Fireblocks Mainnet custody. FIREBLOCKS_POLICY_STATE stays anything other
# than "enforced" until the Stellar proof-of-capability and policy review pass.
FIREBLOCKS_API_BASE_URL=https://api.fireblocks.io
FIREBLOCKS_API_KEY=replace-with-fireblocks-api-key
FIREBLOCKS_PRIVATE_KEY=replace-with-pem-private-key-from-secret-manager
FIREBLOCKS_WEBHOOK_SECRET=replace-with-fireblocks-webhook-secret
FIREBLOCKS_STELLAR_XLM_ASSET_ID=replace-with-fireblocks-xlm-asset-id
FIREBLOCKS_STELLAR_USDC_ASSET_ID=replace-with-fireblocks-stellar-usdc-asset-id
FIREBLOCKS_TREASURY_VAULT_ID=replace-with-capped-treasury-vault-id
FIREBLOCKS_USER_XLM_RESERVE=2
FIREBLOCKS_POLICY_ID=replace-with-approved-policy-id
FIREBLOCKS_POLICY_STATE=pending

# Onramp private white-label partner API. Cash-out fails closed until all
# private endpoints, Stellar USDC entitlement, memo support, and webhooks are live.
ONRAMP_API_BASE_URL=https://replace-with-onramp-partner-api
ONRAMP_APP_ID=replace-with-onramp-app-id
ONRAMP_API_KEY=replace-with-onramp-api-key
ONRAMP_API_SECRET=replace-with-onramp-api-secret
ONRAMP_QUOTE_SIGNING_SECRET=replace-with-onramp-quote-signing-secret
ONRAMP_WEBHOOK_SECRET=replace-with-onramp-webhook-secret

# Operations and observability
CRON_SECRET=replace-with-long-random-cron-secret
OPERATOR_API_TOKEN=replace-with-long-random-operator-token
SENTRY_DSN=https://replace-with-sentry-dsn
RUPI_EXPECTED_RELEASE_SHA=replace-with-the-immutable-deployed-git-sha
RUPI_RELEASE_SHA=replace-with-the-immutable-deployed-git-sha
CASHOUT_ROLLOUT_PERCENTAGE=0
